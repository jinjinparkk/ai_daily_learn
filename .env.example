# === 필수 ===
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxx

# === 선택 ===
# 분석 모델. 기본 claude-opus-4-8. 비용 절감 시 claude-sonnet-5 또는 claude-haiku-4-5
AIDL_MODEL=claude-opus-4-8

# GitHub 트렌드 조회 rate limit 완화용 토큰 (없어도 동작)
GITHUB_TOKEN=

# 사이트 메타
AIDL_SITE_TITLE=AI Daily Learn
AIDL_SITE_TAGLINE=매일 아침, AI가 나를 학습시킨다

# 수집 파라미터
AIDL_ARXIV_CATEGORIES=cs.AI,cs.LG,cs.CL,cs.CV
AIDL_ARXIV_MAX=30
AIDL_GITHUB_TOPICS=llm,agent,rag,machine-learning

# 출력 경로 / 시간대
AIDL_SITE_DIR=site
AIDL_DATA_DIR=data
AIDL_TIMEZONE=Asia/Seoul
